<%= render EmptyStateComponent.new(title: "No files uploaded", description: "Drag and drop files here or click to browse.", bordered: true) do |c| %>
  <% c.with_icon do %>
    <%= icon "inbox" %>
  <% end %>
  <% c.with_primary_action do %>
    <%= render ButtonComponent.new(text: "Upload files", href: "#") %>
  <% end %>
<% end %>
