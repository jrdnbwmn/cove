<%= render EmptyStateComponent.new(title: "No integrations connected", description: "Connect a service to start syncing data automatically.") do |c| %>
  <% c.with_icon do %>
    <%= icon "inbox" %>
  <% end %>
  <% c.with_primary_action do %>
    <%= render ButtonComponent.new(text: "Browse integrations", href: "#") %>
  <% end %>
  <% c.with_secondary_action do %>
    <%= render ButtonComponent.new(text: "Learn more", href: "#", variant: :ghost) %>
  <% end %>
<% end %>
