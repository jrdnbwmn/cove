<%= render EmptyStateComponent.new(title: "No results found", description: "Try adjusting your search or filters.", size: :sm) do |c| %>
  <% c.with_icon do %>
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" class="w-full h-full">
      <circle cx="10.5" cy="10.5" r="6.5" stroke="currentColor" stroke-width="1.5" />
      <path stroke="currentColor" stroke-width="1.5" stroke-linecap="round" d="M20 20l-4.35-4.35" />
    </svg>
  <% end %>
  <% c.with_secondary_action do %>
    <%= render ButtonComponent.new(text: "Clear filters", href: "#", variant: :ghost) %>
  <% end %>
<% end %>
