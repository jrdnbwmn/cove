<h1>Component Kitchen Sink</h1>

<section>
  <h2>Buttons</h2>
  <div class="flex gap-4">
    <%= render ButtonComponent.new(text: "Primary Button") %>
    <div class="dark">
      <%= render ButtonComponent.new(text: "Primary Button") %>
    </div>
  </div>
</section>

<section>
  <h2>Forms</h2>
  <div class="grid gap-6 md:grid-cols-2">
    <%= render FormFieldComponent.new(label: "Display name", name: "profile[display_name]", helper_text: "Shown to collaborators.", required: true) do |component| %>
      <% component.with_input do %>
        <input class="form-control" id="profile_display_name" name="profile[display_name]" type="text">
      <% end %>
    <% end %>

    <%= render FormFieldComponent.new(label: "Biography", name: "profile[biography]", size: :lg) do |component| %>
      <% component.with_input do %>
        <textarea class="form-control" id="profile_biography" name="profile[biography]" rows="3"></textarea>
      <% end %>
    <% end %>

    <%= render FormFieldComponent.new(label: "Plan", name: "subscription[plan]", variant: :inline, size: :sm) do |component| %>
      <% component.with_input do %>
        <select class="form-control" id="subscription_plan" name="subscription[plan]"><option>Starter</option><option>Team</option></select>
      <% end %>
    <% end %>

    <%= render FormFieldComponent.new(label: "Email", name: "user[email]", error: "Email is invalid.", variant: :floating) do |component| %>
      <% component.with_input do %>
        <input class="form-control error" id="user_email" name="user[email]" type="email">
      <% end %>
    <% end %>

    <%= render FormFieldComponent.new(label: "Account ID", name: "account[id]", disabled: true, size: :md) do |component| %>
      <% component.with_input do %>
        <input class="form-control" disabled id="account_id" name="account[id]" type="text" value="ACC-123">
      <% end %>
    <% end %>
  </div>

  <div class="dark mt-6 bg-neutral-900 p-4">
    <%= render FormFieldComponent.new(label: "Dark mode field", name: "dark[field]", helper_text: "RB form-control styling in dark mode.") do |component| %>
      <% component.with_input do %>
        <input class="form-control" id="dark_field" name="dark[field]" type="text">
      <% end %>
    <% end %>
  </div>

  <div class="mt-6 grid gap-6 md:grid-cols-2">
    <%= render CheckboxComponent.new(label: "Receive product updates", name: "preferences[product_updates]", checked: true, description: "A checked checkbox with supporting text.") %>
    <%= render RadioComponent.new(label: "Team", name: "plan", value: "team", checked: true, description: "A selected radio option.") %>
    <%= render SwitchComponent.new(label: "Enable weekly summary", name: "preferences[weekly_summary]", checked: true, show_icons: true) %>
    <%= render SelectComponent.new(label: "Plan", name: "subscription[plan]", options: [["Starter", "starter"], ["Team", "team"], ["Enterprise", "enterprise"]]) %>
    <%= render PasswordComponent.new(name: "user[password]", hint: "Use at least 8 characters.") %>
  </div>

  <div class="dark mt-6 grid gap-6 bg-neutral-900 p-4 md:grid-cols-2">
    <%= render CheckboxComponent.new(label: "Dark mode checkbox", name: "dark[checkbox]", error: "Choose an option.") %>
    <%= render RadioComponent.new(label: "Dark mode radio", name: "dark_radio", value: "selected", disabled: true) %>
    <%= render SwitchComponent.new(label: "Dark mode switch", name: "dark[switch]", disabled: true) %>
    <%= render SelectComponent.new(label: "Dark mode select", name: "dark[select]", options: [["Monthly", "monthly"]], disabled: true) %>
    <%= render PasswordComponent.new(name: "dark[password]", error: "Password is too short.") %>
  </div>
</section>

<section>
  <h2>Feedback</h2>
  <div class="grid gap-4 md:grid-cols-2">
    <%= render AlertComponent.new(title: "Success! Your changes have been saved", description: "All updates have been applied successfully.", variant: :success) %>
    <%= render AlertComponent.new(title: "Something went wrong", description: "We couldn't process your request.", variant: :error) %>
    <%= render AlertComponent.new(title: "Your plan is expiring soon", variant: :warning) %>
    <%= render AlertComponent.new(title: "New features are available", variant: :info) %>
  </div>

  <div class="mt-6 flex flex-wrap items-center gap-3">
    <%= render BadgeComponent.new(text: "Neutral") %>
    <%= render BadgeComponent.new(text: "Published", variant: :green) %>
    <%= render BadgeComponent.new(text: "Active", variant: :blue, dot: true) %>
    <%= render BadgeComponent.new(text: "Beta", variant: :purple, pill: true) %>
    <%= render BadgeComponent.new(text: "Filter: Active", variant: :neutral, removable: true) %>
  </div>

  <div class="mt-6 flex flex-wrap items-center gap-6">
    <%= render LoadingIndicatorComponent.new %>
    <%= render LoadingIndicatorComponent.new(stepped: true) %>
    <%= render LoadingIndicatorComponent.new(type: :dots) %>
    <%= render LoadingIndicatorComponent.new(type: :bars) %>
    <%= render LoadingIndicatorComponent.new(type: :progress, progress: 65) %>
    <%= render LoadingIndicatorComponent.new(color: :primary, text: "Loading...") %>
  </div>

  <div class="mt-6 grid max-w-sm gap-2">
    <%= render SkeletonComponent.new %>
    <%= render SkeletonComponent.new(variant: :circle) %>
    <%= render SkeletonComponent.new(variant: :button) %>
    <%= render SkeletonComponent.new(count: 3) %>
  </div>

  <div class="dark mt-6 grid gap-4 bg-neutral-900 p-4 md:grid-cols-2">
    <%= render AlertComponent.new(title: "Dark mode success", variant: :success) %>
    <%= render AlertComponent.new(title: "Dark mode error", variant: :error) %>
    <div class="flex flex-wrap items-center gap-3">
      <%= render BadgeComponent.new(text: "Dark neutral") %>
      <%= render BadgeComponent.new(text: "Dark active", variant: :blue, dot: true) %>
    </div>
    <div class="flex flex-wrap items-center gap-6">
      <%= render LoadingIndicatorComponent.new %>
      <%= render LoadingIndicatorComponent.new(color: :primary) %>
    </div>
  </div>
</section>

