<% Current.meta_tags.set(title: @api_token.name) %>

<% content_for :sidebar, render(partial: "account_navbar") %>

<div class="sm:flex justify-between items-center mb-4">
  <div class="flex items-center">
    <h1 class="h3 mb-4">
      <%= link_to t("api_tokens.index.title"), api_tokens_path, class: "hover:text-primary" %>

      <%= icon "chevron-right", class: "inline-block size-5 text-muted-foreground" %>

      <%= @api_token.name %>
    </h1>
  </div>

  <div class="flex shrink-0 gap-3">
    <%= render ButtonComponent.new(text: t(".edit"), variant: :secondary, href: edit_api_token_path(@api_token)) %>
    <%= render ButtonComponent.new(
      text: t(".revoke"),
      variant: :destructive,
      href: api_token_path(@api_token),
      data: {turbo_method: :delete, turbo_confirm: t(".confirm")}
    ) %>
  </div>
</div>

<div class="mb-4">
  <div class="mb-2 text-muted-foreground text-xs uppercase font-bold"><%= ApiToken.human_attribute_name(:token) %></div>
  <div class="flex items-center gap-1">
    <%= blur_secret @api_token.token %>

    <%= button_tag data: {controller: "clipboard tooltip", tooltip_content_value: t(".click_to_copy"), clipboard_text: @api_token.token} do %>
      <%= icon "copy", class: "size-5" %>
    <% end %>
  </div>
</div>

<div class="mb-4">
  <div class="mb-2 text-muted-foreground text-xs uppercase font-bold"><%= ApiToken.human_attribute_name(:created_at) %></div>
  <%= @api_token.created_at.strftime("%b %e, %Y") %>
</div>

<div class="mb-4">
  <div class="mb-2 text-muted-foreground text-xs uppercase font-bold"><%= ApiToken.human_attribute_name(:last_used_at) %></div>
  <%= @api_token.last_used_at? ? local_time_ago(@api_token.last_used_at) : "—" %>
</div>

<hr>

<div>
  <div class="mb-4 text-muted-foreground text-xs uppercase font-bold"><%= t(".auth_header") %></div>
  <div class="whitespace-pre-wrap">GET /api/v1/me.json
Accept: application/json
Authorization: Bearer <%= blur_secret @api_token.token %></div>

  <div class="mt-4 whitespace-pre-wrap">curl <%= api_v1_me_url(format: :json) %>
-H "Accept: application/json"
-H "Authorization: Bearer <%= blur_secret @api_token.token %>"</div>
</div>
