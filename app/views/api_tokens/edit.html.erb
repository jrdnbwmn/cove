<% Current.meta_tags.set(title: t(".title")) %>

<% content_for :sidebar, render(partial: "account_navbar") %>

<h1 class="h3 mb-4">
  <%= icon "key-round", class: "inline-block size-5 text-muted-foreground" %>

  <%= link_to t("api_tokens.index.title"), api_tokens_path, class: "hover:text-primary" %>

  <%= icon "chevron-right", class: "inline-block size-5 text-muted-foreground" %>

  <%= link_to @api_token.name, @api_token, class: "hover:text-primary" %>

  <%= icon "chevron-right", class: "inline-block size-5 text-muted-foreground" %>

  <%= t(".title") %>
</h1>

<%= render "form", api_token: @api_token %>
