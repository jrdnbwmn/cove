<% Current.meta_tags.set(title: t(".title")) %>

<% content_for :sidebar, render(partial: "account_navbar") %>

<div class="flex items-center gap-4">
  <%= account_avatar @account %>
  <h1 class="h3 text-foreground">
    <%= link_to @account.name, @account, class: "hover:text-primary" %>

    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="inline-block size-5 text-muted-foreground">
      <path fill-rule="evenodd" d="M8.22 5.22a.75.75 0 0 1 1.06 0l4.25 4.25a.75.75 0 0 1 0 1.06l-4.25 4.25a.75.75 0 0 1-1.06-1.06L11.94 10 8.22 6.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" />
    </svg>

    <%= t(".title") %>
  </h1>
</div>

<p class="mt-2 mb-8 text-sm text-muted-foreground"><%= t(".description") %></p>

<%= form_with(model: @account_invitation, url: account_account_invitations_path(@account), class: "max-w-md") do |form| %>
  <%= render "error_messages", resource: form.object %>

  <%= render FormFieldComponent.new(
    label: form.object.class.human_attribute_name(:name),
    name: "account_invitation[name]",
    required: true,
    error: form.object.errors[:name].first,
    classes: "mb-6"
  ) do |field| %>
    <% field.with_input do %>
      <%= form.text_field :name, class: "form-control", required: true, placeholder: true %>
    <% end %>
  <% end %>

  <%= render FormFieldComponent.new(
    label: form.object.class.human_attribute_name(:email),
    name: "account_invitation[email]",
    required: true,
    error: form.object.errors[:email].first,
    classes: "mb-6"
  ) do |field| %>
    <% field.with_input do %>
      <%= form.email_field :email, class: "form-control", required: true, placeholder: true %>
    <% end %>
  <% end %>

  <h2 class="mb-4 text-lg font-semibold text-foreground"><%= t("accounts.roles") %></h2>
  <div class="mb-6 space-y-3">
    <% AccountUser::ROLES.each do |role| %>
      <%# AIDEV-NOTE: CheckboxComponent does not generate Rails' companion unchecked value. %>
      <%= hidden_field_tag "account_invitation[#{role}]", "0", id: nil %>
      <%= render CheckboxComponent.new(
        label: role.to_s.humanize,
        name: "account_invitation[#{role}]",
        id: role.to_s.parameterize,
        value: "1",
        checked: form.object.public_send(role)
      ) %>
    <% end %>
  </div>

  <div class="flex gap-3">
    <%= render ButtonComponent.new(text: t(".send"), type: "submit") %>
    <%= render ButtonComponent.new(text: t("cancel"), variant: :secondary, href: @account) %>
  </div>
<% end %>
