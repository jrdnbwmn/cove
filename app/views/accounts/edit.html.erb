<% Current.meta_tags.set(title: t(".title")) %>

<% content_for :sidebar, render(partial: "account_navbar") %>

<div class="mb-4 flex items-center justify-between">
  <div class="flex items-center gap-4">
    <%= account_avatar @account %>
    <h1 class="h3 text-foreground">
      <%= link_to @account.name, @account, class: "hover:text-primary" %>

      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="inline-block size-5 text-muted-foreground">
        <path fill-rule="evenodd" d="M8.22 5.22a.75.75 0 0 1 1.06 0l4.25 4.25a.75.75 0 0 1 0 1.06l-4.25 4.25a.75.75 0 0 1-1.06-1.06L11.94 10 8.22 6.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" />
      </svg>

      <%= t(".title") %>
    </h1>
  </div>

  <%= button_to t("delete"), @account, {method: :delete, class: "inline-flex items-center justify-center rounded-[var(--radius)] border border-red-300/30 bg-red-600 px-3.5 py-2 text-sm font-medium text-white shadow-sm transition-all hover:bg-red-500", data: { turbo_confirm: t("are_you_sure"), turbo_confirm_description: subscribed? ? t(".delete_with_payments_description") : t(".delete_description") } } if !@account.personal? %>
</div>

<%= render "form", account: @account %>

<hr class="my-8 border-(--border)">

<%= render "accounts/transfers/form", account: @account if @account.can_transfer?(current_user) %>
