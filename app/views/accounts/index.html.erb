<% Current.meta_tags.set(title: t(".title")) %>

<% content_for :sidebar, render(partial: "account_navbar") %>

<div class="sm:flex items-center justify-between mb-3">
  <h1 class="flex-1 h3"><%= t(".title") %></h1>

  <div>
    <%= render ButtonComponent.new(text: t(".create"), href: new_account_path) if Jumpstart.config.team_accounts? %>
  </div>
</div>

<%= render TableComponent.new(hoverable: true) do |table| %>
  <% @accounts.sorted.each do |account| %>
    <% table.with_row do |row| %>
      <% row.with_cell(primary: true) do %>
        <%= link_to account, class: "flex items-center gap-3" do %>
          <%= account_avatar account %>
          <%= tag.span account.name, class: "text-foreground dark:text-gray-100 font-semibold text-sm no-underline hover:text-primary-500 dark:hover:text-primary-500" %>
          <%= render BadgeComponent.new(text: "Personal", size: :sm) if account.personal_account_for?(current_user) %>
        <% end %>
      <% end %>

      <% row.with_cell do %>
        <%= pluralize account.users.size, t(".user") %>
      <% end %>

      <% row.with_cell(align: :right, classes: "hidden sm:table-cell") do %>
        <% if current_account != account %>
          <%= switch_account_button account, label: t(".switch"), class: "inline-flex items-center justify-center gap-1.5 font-medium whitespace-nowrap transition-all duration-100 ease-in-out select-none focus-visible:outline-2 focus-visible:outline-offset-2 disabled:cursor-not-allowed disabled:opacity-50 px-3.5 py-2 text-sm rounded-[var(--radius)] border border-black/10 bg-white/90 text-neutral-800 shadow-xs hover:bg-muted focus-visible:outline-neutral-600 dark:border-white/10 dark:bg-neutral-700/50 dark:text-neutral-50 dark:hover:bg-neutral-700/75 dark:focus-visible:outline-neutral-200" %>
        <% else %>
          <%= render BadgeComponent.new(text: t(".current"), size: :sm) %>
        <% end %>
      <% end %>
    <% end %>
  <% end %>
<% end %>

<% if @pagy.last > 1 %>
  <div class="my-6">
    <%= render PaginationComponent.new(pagy: @pagy, classes: "justify-center") %>
  </div>
<% end %>
