<% Current.meta_tags.set(title: t(".title", account: @account.name)) %>

<div class="mx-auto mt-12 max-w-md text-center">
  <h1 class="h3 text-foreground"><%= t(".title", account: @account.name) %></h1>

  <div class="mt-8 flex items-center justify-center gap-2 text-sm text-muted-foreground">
    <%= render AvatarComponent.new(
      src: avatar_url_for(@account_invitation.account),
      alt: @account_invitation.account.name,
      size: :xs
    ) %>

    <div>
      <%= t(".invited_you_to_join_html", inviter: @account_invitation.invited_by.name, account: @account_invitation.account.name) %>
    </div>
  </div>

  <div class="mt-8 flex justify-center gap-3">
    <%= button_to t(".accept"), account_invitation_path(@account_invitation.token), method: :put, class: "inline-flex items-center justify-center gap-1.5 rounded-[var(--radius)] border border-neutral-400/30 bg-primary px-3.5 py-2 text-sm font-medium whitespace-nowrap text-primary-foreground shadow-sm transition-all duration-100 ease-in-out hover:bg-neutral-700 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-neutral-600 dark:hover:bg-neutral-100 dark:focus-visible:outline-neutral-200" %>
    <%= button_to t(".decline"), account_invitation_path(@account_invitation.token), method: :delete, class: "inline-flex items-center justify-center gap-1.5 rounded-[var(--radius)] border border-black/10 bg-white/90 px-3.5 py-2 text-sm font-medium whitespace-nowrap text-neutral-800 shadow-xs transition-all duration-100 ease-in-out hover:bg-muted focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-neutral-600 dark:border-white/10 dark:bg-neutral-700/50 dark:text-neutral-50 dark:hover:bg-neutral-700/75 dark:focus-visible:outline-neutral-200", data: { turbo_confirm: t("are_you_sure") } %>
  </div>
</div>
