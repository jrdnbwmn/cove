<template id="turbo-resilience-frame-failure-template">
  <div data-turbo-resilience-notice role="alert">
    <%= render AlertComponent.new(
      title: t("turbo_resilience.frame.title"),
      description: t("turbo_resilience.frame.description"),
      variant: :error
    ) %>
    <div class="mt-3" data-turbo-resilience-retry>
      <%= render ButtonComponent.new(
        text: t("turbo_resilience.frame.retry"),
        variant: :secondary,
        type: "button",
        data: {action: "click->turbo-resilience#retryFrame:stop"}
      ) %>
    </div>
  </div>
</template>

