<% people_icon = icon "users", class: "size-5" %>

<%= render DropdownComponent.new(placement: "bottom-start") do |dropdown| %>
  <% dropdown.with_trigger do %>
    <button
      type="button"
      class="flex max-w-48 items-center gap-2 rounded-md px-2 py-1.5 text-sm font-medium text-foreground hover:bg-muted focus-visible:outline-2 focus-visible:outline-ring"
      data-ui-dropdown-popover-target="button"
      data-action="click->ui-dropdown-popover#toggle"
      aria-label="Account Menu"
      aria-haspopup="menu"
    >
      <%= account_avatar current_account, size: "size-6" %>
      <span class="truncate"><%= current_account.name %></span>
    </button>
  <% end %>

  <% Current.other_accounts.each do |account| %>
    <% dropdown.with_item_custom do %>
      <%= switch_account_button account, data: { controller: :accounts, action: "ajax:success->accounts#reconnect" } do %>
        <%= account_avatar account, size: "size-6" %>
        <span><%= account.name %></span>
      <% end %>
    <% end %>
  <% end %>

  <% dropdown.with_item_divider %>
  <% dropdown.with_item_link(text: t(".manage_accounts"), href: accounts_path, icon: people_icon) %>
<% end %>
