<% if Jumpstart.config.stripe? %>
  <div class="container mx-auto my-12 max-w-5xl px-4 sm:px-6">
    <div class="mx-auto max-w-3xl">
      <h1 class="mb-6 text-center text-3xl font-bold text-foreground sm:mb-8 sm:text-4xl"><%= t(".title") %></h1>
      <%= render "checkouts/forms/stripe", client_secret: @checkout_session.client_secret %>
      <%= render "testimonial" %>
    </div>
  </div>
<% else %>
  <div class="mx-auto grid max-w-6xl gap-8 p-4 lg:grid-cols-2 lg:gap-16 lg:py-24">
    <div>
      <div class="mb-6 flex justify-center lg:justify-start">
        <% if @plan.has_trial? %>
          <div>
            <h1 class="text-lg font-semibold text-muted-foreground">Try <%= @plan.name %></h1>
            <h3 class="my-1 text-3xl font-bold text-foreground"><%= @plan.trial_period_days %> days free</h3>
            <p class="font-medium text-muted-foreground">Then <span id="recurringTotal"><%= pay_amount_to_currency(@plan) %></span> per <%= formatted_plan_interval(@plan) %></p>
          </div>

        <% else %>
          <div>
            <h1 class="text-lg font-semibold text-muted-foreground">Subscribe to <%= @plan.name %></h1>

            <div class="flex items-center">
              <h3 id="recurringTotal" class="my-1 text-4xl font-bold text-foreground"><%= pay_amount_to_currency(@plan) %></h3>

              <div class="ml-2 text-sm leading-none font-medium text-muted-foreground">
                <% if @plan.unit_label? %>
                  <div>per <%= @plan.unit_label %></div>
                  <div>per <%= formatted_plan_interval(@plan) %></div>
                <% else %>
                  <div>per</div>
                  <div><%= formatted_plan_interval(@plan) %></div>
                <% end %>
              </div>
            </div>
          </div>
        <% end %>
      </div>

      <% if @plan.taxed? && @stripe_invoice %>
        <%= render CardComponent.new(padding: :sm, classes: "mb-6") do %>
          <div class="mb-4 flex justify-between text-sm font-medium text-foreground">
            <div><%= t(".subtotal") %></div>
            <div><%= Pay::Currency.format(@stripe_invoice.subtotal, currency: @stripe_invoice.currency) %></div>
          </div>

          <div class="border-t border-(--divider-color) pt-4">
            <div class="mb-4 flex justify-between text-sm text-muted-foreground">
              <% @stripe_invoice.total_tax_amounts.each do |tax| %>
                <div>
                  <%= tax.tax_rate.jurisdiction %>
                  <%= tax.tax_rate.display_name %>
                  (<%= tax.tax_rate.percentage %>%)
                </div>
                <div><%= Pay::Currency.format(tax.amount, currency: @stripe_invoice.currency) %></div>
              <% end %>
            </div>
          </div>

          <div class="flex justify-between border-t border-(--divider-color) pt-4 text-sm font-medium text-foreground">
            <div><%= t(".total") %></div>
            <div><%= Pay::Currency.format(@stripe_invoice.total, currency: @stripe_invoice.currency) %></div>
          </div>
        <% end %>
      <% end %>

      <div class="mb-6 hidden justify-center lg:flex lg:justify-start">
        <div>
          <% @plan.features.each do |plan_feature| %>
            <div class="mb-2 flex text-muted-foreground">
              <%= icon "check", class: "mr-2 size-5 shrink-0 text-primary" %>
              <div><%= plan_feature %></div>
            </div>
          <% end %>
        </div>
      </div>

      <%= render "subscriptions/new/testimonial" %>
    </div>

    <div>
      <h1 class="mb-4 hidden text-3xl font-bold text-foreground lg:block"><%= t(".title") %></h1>

      <%= render CardComponent.new(divide: true, classes: "lg:mt-0") do |card| %>
        <% card.with_header do %>
          <h5 class="font-semibold text-muted-foreground"><%= t(".account") %></h5>
        <% end %>

        <% card.with_body do %>
          <div class="flex items-center gap-4">
            <%= render AvatarComponent.new(src: avatar_url_for(current_account), alt: current_account.name, size: :md) %>
            <h4 class="font-semibold text-foreground"><%= current_account.name %></h4>
          </div>
        <% end %>

        <% card.with_footer do %>
          <h5 class="mb-4 font-semibold text-muted-foreground"><%= t("subscriptions.new.payment_method") %></h5>
          <div>
            <%= render 'checkouts/forms/paddle_billing' if Jumpstart.config.paddle_billing? %>
            <%= render 'checkouts/forms/paddle_classic' if Jumpstart.config.paddle_classic? %>
            <%= render 'checkouts/forms/braintree' if Jumpstart.config.braintree? %>
            <%= render 'checkouts/forms/paypal' if Jumpstart.config.paypal? %>

            <% if @plan.has_trial? %>
              <p class="mt-4 text-center text-sm text-muted-foreground">After your trial ends, you will be charged <%= pay_amount_to_currency(@plan) %> per <%= formatted_plan_interval(@plan) %> starting <%= l @plan.trial_period_days.days.from_now.to_date, format: :long %>. You can always cancel before then.</p>
            <% else %>
              <p class="mt-4 text-center text-sm text-muted-foreground">By confirming your subscription, you allow <%= Jumpstart.config.application_name %> to charge your payment method for this payment and future payments in accordance with our terms.</p>
            <% end %>
          </div>
        <% end %>
      <% end %>

      <div class="mt-8 text-center text-sm">
        <%= icon "circle-question-mark", class: "inline-block size-5 text-muted-foreground" %>
        <%= t(".help") %>
        <span class="text-muted-foreground">
          <%= t(".contact_html", link: mail_to(Jumpstart.config.support_email, t(".contact_support"), subject: t(".contact_subject", product: Jumpstart.config.application_name), class: "underline text-foreground hover:text-primary")) %>
        </span>
      </div>
    </div>
  </div>
<% end %>
