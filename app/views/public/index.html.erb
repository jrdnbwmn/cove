<div class="py-32 max-w-2xl m-auto text-center flex flex-col items-center justify-center">
  <h1 class="mb-2">Welcome to Jumpstart</h1>
  <p class="mb-6 text-muted-foreground leading-normal text-xl">Jumpstart is the perfect starting point for your next Ruby on Rails app. Skip the boilerplate setup and build your app faster.</p>
  <% if Rails.env.development? %>
    <div class="flex flex-col items-center gap-4">
      <%= render ButtonComponent.new(text: "Configure Jumpstart", variant: :primary, href: jumpstart_path, data: { turbo: false }) %>
      <%= render ButtonComponent.new(text: "Read the Docs", variant: :outline, href: jumpstart.docs_path, target: "_blank", data: { turbo: false }) %>
    </div>
  <% end %>
</div>
