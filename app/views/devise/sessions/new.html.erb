<% Current.meta_tags.set(title: t(".title")) %>

<div class="sm:max-w-sm px-4 mx-auto my-10 lg:px-0">
  <div class="mb-4 text-center">
    <h2 class="mb-px"><%= t(".sign_in") %></h2>
    <%= t ".sign_up_html", link: link_to(t(".sign_up"), new_registration_path(resource_name)) %>
  </div>

  <%= form_with(model: resource, as: resource_name, url: session_path(resource_name)) do |f| %>
    <%= render FormFieldComponent.new(
      label: resource.class.human_attribute_name(:email),
      name: "user[email]",
      error: resource.errors[:email].first,
      classes: "mb-6"
    ) do |field| %>
      <% field.with_input do %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", placeholder: true, class: "form-control" %>
      <% end %>
    <% end %>

    <%= render PasswordComponent.new(
      name: "user[password]",
      id: "user_password",
      autocomplete: "current-password",
      placeholder: true,
      error: resource.errors[:password].first,
      classes: "mb-6"
    ) %>

    <% if devise_mapping.rememberable? -%>
      <% if hotwire_native_app? %>
        <%= f.hidden_field :remember_me, value: true %>
      <% else %>
        <%= render CheckboxComponent.new(
          label: resource.class.human_attribute_name(:remember_me),
          name: "user[remember_me]",
          checked: resource.remember_me,
          error: resource.errors[:remember_me].first,
          classes: "mb-6"
        ) %>
      <% end -%>
    <% end -%>

    <%= render ButtonComponent.new(text: t(".sign_in"), type: "submit", full_width: true) %>
  <% end %>

  <%= render "devise/shared/links" %>
</div>
