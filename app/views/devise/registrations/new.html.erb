<% Current.meta_tags.set(title: t(".title")) %>

<div class="sm:max-w-sm px-4 mx-auto my-10 lg:px-0">
  <div class="mb-4 text-center">
    <h2 class="mb-1"><%= t('.sign_up') %></h2>
    <%= t(".login_html", link: link_to(t(".login"), new_session_path(resource_name))) %>
  </div>

  <% if @account_invitation %>
    <%= render AlertComponent.new(
      title: t(".invited_you_to_join_html", inviter: @account_invitation.invited_by.name, account: @account_invitation.account.name),
      variant: :info,
      custom_icon: image_tag(avatar_url_for(@account_invitation.account), class: "h-5 w-5 rounded-full"),
      classes: "mb-4"
    ) %>
  <% end %>

  <%= form_with(model: resource, as: resource_name, url: registration_path(resource_name, invite: params[:invite])) do |f| %>
    <%= render "error_messages", resource: resource %>

    <%# Add any extra fields when creating an Account as part of registration %>
    <!--
    <%= f.fields_for :owned_accounts do |a| %>
      <div class="form-group">
        <%= a.label :name %>
        <%= a.text_field :name, autofocus: true, placeholder: true, class: "form-control" %>
      </div>
    <% end %>
    -->

    <%= render FormFieldComponent.new(
      label: resource.class.human_attribute_name(:name),
      name: "user[name]",
      error: resource.errors[:name].first,
      classes: "mb-6"
    ) do |field| %>
      <% field.with_input do %>
        <%= f.text_field :name, autocomplete: "name", placeholder: true, class: "form-control" %>
      <% end %>
    <% end %>

    <%= render FormFieldComponent.new(
      label: resource.class.human_attribute_name(:email),
      name: "user[email]",
      error: resource.errors[:email].first,
      classes: "mb-6"
    ) do |field| %>
      <% field.with_input do %>
        <%= f.email_field :email, autocomplete: "email", placeholder: true, class: "form-control" %>
      <% end %>
    <% end %>

    <%= render PasswordComponent.new(
      name: "user[password]",
      id: "user_password",
      autocomplete: "new-password",
      placeholder: true,
      error: resource.errors[:password].first,
      hint: @minimum_password_length && t("devise.shared.minimum_password_length", count: @minimum_password_length),
      classes: "mb-6"
    ) %>

    <div class="mb-6">
      <%= invisible_captcha %>
    </div>

    <%= render CheckboxComponent.new(
      label: t(".terms_of_service"),
      label_html: t(".terms_html", terms: link_to(t(".terms_of_service"), terms_path, target: "_blank"), privacy: link_to(t(".privacy_policy"), privacy_path, target: "_blank")),
      name: "user[terms_of_service]",
      id: "tos",
      checked: resource.terms_of_service,
      error: resource.errors[:terms_of_service].first,
      classes: "mb-6"
    ) %>

    <%= render ButtonComponent.new(
      text: t('.sign_up'),
      type: "submit",
      full_width: true,
      data: {disable_with: t(".submitting")}
    ) %>
  <% end %>

  <%= render "devise/shared/links" %>
</div>
