<h2 class="mt-8 mb-4 border-b border-(--divider-color) pb-2 text-lg font-semibold text-foreground"><%= t(".billing_email") %></h2>

<div class="mb-8">
  <%= form_with model: current_account, url: billing_path do |f| %>
    <p class="mb-4 text-muted-foreground"><%= t ".description" %></p>

    <div class="flex flex-wrap items-end gap-3">
      <%= render FormFieldComponent.new(
        label: current_account.class.human_attribute_name(:billing_email),
        name: "account[billing_email]",
        error: current_account.errors[:billing_email].first,
        classes: "w-full max-w-80"
      ) do |field| %>
        <% field.with_input do %>
          <%= f.email_field :billing_email, class: "form-control", placeholder: true %>
        <% end %>
      <% end %>
      <%= render ButtonComponent.new(text: t(".save"), variant: :secondary, type: "submit", data: { disable_with: t(".saving") }) %>
    </div>
  <% end %>
</div>
