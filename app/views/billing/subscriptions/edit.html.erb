<% if @subscription.on_trial? %>
  <%= render AlertComponent.new(title: t(".trial_ends", days: time_ago_in_words(@subscription.trial_ends_at)), variant: :warning, classes: "mb-6") %>
<% end %>

<div class="container m-auto my-12">
  <div class="flex flex-wrap justify-center">
    <div class="text-center">
      <h1><%= t(".title") %></h1>
      <p class="mt-2 text-xl text-muted"><%= t(".description") %></p>
    </div>
  </div>

  <div data-controller="pricing"
       data-pricing-frequency-value="<%= @subscription.plan&.yearly? ? "yearly" : "monthly" %>"
       data-pricing-active-frequency-class="shadow-xs text-black hover:text-black bg-background dark:text-white dark:hover:text-white dark:bg-gray-900"
       data-pricing-inactive-frequency-class=""
       data-pricing-inactive-plans-class="hidden"
       data-pricing-hidden-toggle-class="hidden"
       class="sm:flex flex-wrap items-center justify-center">
    <div data-pricing-target="toggle" class="hidden relative self-center my-8 bg-(--divider-color) rounded-full p-0.5 flex sm:mt-8">
      <button type="button" data-action="pricing#switch" data-pricing-target="frequency" data-frequency="monthly" class="relative w-1/2 border-border rounded-full py-2 text-sm font-medium whitespace-nowrap focus:outline-hidden focus:z-10 sm:w-auto sm:px-8"><%= t(".monthly") %></button>
      <button type="button" data-action="pricing#switch" data-pricing-target="frequency" data-frequency="yearly" class="ml-0.5 relative w-1/2 border border-transparent rounded-full py-2 text-sm font-medium whitespace-nowrap focus:outline-hidden focus:z-10 sm:w-auto sm:px-8"><%= t(".yearly") %></button>
    </div>

    <div data-turbo-prefetch="false" class="w-full lg:px-0 px-2">
      <div data-pricing-target="plans" data-frequency="monthly" class="grid lg:grid-flow-col lg:auto-cols-fr gap-4">
        <% @monthly_plans.each do |plan| %>
          <%= render PlanCardComponent.new(plan: plan) do %>
            <% if @subscription.plan == plan %>
              <%= render ButtonComponent.new(text: t("billing.subscriptions.plan.current_plan"), variant: :secondary, full_width: true, disabled: true) %>
            <% else %>
              <%= form_with url: billing_subscription_url(@subscription), method: :patch do |f| %>
                <%= f.hidden_field :plan, value: plan.to_param %>
                <%= render ButtonComponent.new(text: t("billing.subscriptions.plan.change_plan"), variant: :secondary, type: "submit", full_width: true, data: { disable_with: t("billing.subscriptions.plan.processing"), turbo_confirm: "Are you sure?" }) %>
              <% end %>
            <% end %>
          <% end %>
        <% end %>
      </div>

      <div data-pricing-target="plans" data-frequency="yearly" class="hidden grid lg:grid-flow-col lg:auto-cols-fr gap-4">
        <% @yearly_plans.each do |plan| %>
          <%= render PlanCardComponent.new(plan: plan) do %>
            <% if @subscription.plan == plan %>
              <%= render ButtonComponent.new(text: t("billing.subscriptions.plan.current_plan"), variant: :secondary, full_width: true, disabled: true) %>
            <% else %>
              <%= form_with url: billing_subscription_url(@subscription), method: :patch do |f| %>
                <%= f.hidden_field :plan, value: plan.to_param %>
                <%= render ButtonComponent.new(text: t("billing.subscriptions.plan.change_plan"), variant: :secondary, type: "submit", full_width: true, data: { disable_with: t("billing.subscriptions.plan.processing"), turbo_confirm: "Are you sure?" }) %>
              <% end %>
            <% end %>
          <% end %>
        <% end %>
      </div>
    </div>
  </div>
</div>
