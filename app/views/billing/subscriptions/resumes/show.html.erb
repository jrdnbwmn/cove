<% Current.meta_tags.set(title: t(".title")) %>

<% content_for :sidebar, render(partial: "account_navbar") %>

<div class="mx-auto mt-12 max-w-xl">
  <h1 class="h3 text-foreground"><%= t ".title" %></h1>

  <%= render CardComponent.new(divide: true, classes: "mt-8") do |card| %>
    <% card.with_header do %>
      <%= render partial: "billing/subscriptions/summary", locals: { subscription: @subscription } %>
    <% end %>

    <% card.with_body do %>
      <%= render AlertComponent.new(title: t(".resume"), variant: :info, show_icon: false) %>
    <% end %>

    <% card.with_footer do %>
      <div class="flex items-center justify-between gap-3">
        <%= render ButtonComponent.new(text: t(".back"), variant: :secondary, href: billing_path) %>

        <%= button_to billing_subscription_resume_path(@subscription), method: :patch, class: "inline-flex items-center justify-center gap-1.5 rounded-[var(--radius)] border border-neutral-400/30 bg-primary px-3.5 py-2 text-sm font-medium whitespace-nowrap text-primary-foreground shadow-sm transition-all duration-100 ease-in-out hover:bg-neutral-700 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-neutral-600 dark:hover:bg-neutral-100 dark:focus-visible:outline-neutral-200", form: { data: { turbo_confirm: t("are_you_sure") } } do %>
          <%= button_text t(".button"), disable_with: t(".processing") %>
        <% end %>
      </div>
    <% end %>
  <% end %>
</div>
