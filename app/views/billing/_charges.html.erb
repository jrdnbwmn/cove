<h2 class="mt-8 mb-4 border-b border-(--divider-color) pb-2 text-lg font-semibold text-foreground"><%= t(".title") %></h2>

<% if (charges = current_account.pay_charges.sorted) && charges.any? %>
  <%= render TableComponent.new(hoverable: true) do |table| %>
    <% table.with_column(label: t(".date")) %>
    <% table.with_column(label: t(".amount")) %>
    <% table.with_column(label: t(".invoice"), align: :center) %>
    <% table.with_column(label: t(".receipt"), align: :center) %>

    <% charges.each do |charge| %>
      <% table.with_row do |row| %>
        <% row.with_cell(primary: true) do %>
          <%= charge.created_at.strftime("%B %e, %Y") %>
        <% end %>
        <% row.with_cell do %>
          <%= pay_amount_to_currency(charge) %>
        <% end %>
        <% row.with_cell(align: :center) do %>
          <%= link_to invoice_billing_charge_path(charge, format: :pdf), target: :_blank do %>
            <%= icon "download", class: "inline-block size-5 text-muted-foreground" %>
          <% end %>
        <% end %>
        <% row.with_cell(align: :center) do %>
          <%= link_to billing_charge_path(charge, format: :pdf), target: :_blank do %>
            <%= icon "download", class: "inline-block size-5 text-muted-foreground" %>
          <% end %>
        <% end %>
      <% end %>
    <% end %>
  <% end %>
<% else %>
  <p class="text-muted-foreground"><%= t(".empty") %></p>
<% end %>
