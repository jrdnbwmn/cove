<label class="<%= wrapper_classes %>">
  <div class="<%= control_wrapper_classes %>">
    <input
      type="checkbox"
      id="<%= @id %>"
      <% if @name.present? %>name="<%= @name %>"<% end %>
      value="<%= @value %>"
      class="sr-only peer"
      <% if @checked %>checked<% end %>
      <% if @disabled %>disabled<% end %>
      <% if @required %>required<% end %>
    >
    <!-- Track -->
    <div class="<%= track_classes %>"></div>
    <!-- Thumb -->
    <div class="<%= thumb_classes %>">
      <% if @show_icons %>
        <!-- X icon for unchecked state -->
        <%= icon "x", class: "#{icon_size_classes} text-neutral-400 transition-all duration-150 ease-in-out group-has-[:checked]:opacity-0 dark:text-neutral-500" %>
        <!-- Checkmark icon for checked state -->
        <%= icon "check", class: "absolute #{icon_size_classes} text-neutral-700 transition-all duration-150 ease-in-out opacity-0 group-has-[:checked]:opacity-100 dark:text-neutral-100" %>
      <% end %>
    </div>
  </div>

  <% if @label.present? %>
    <div class="<%= text_content_classes %>">
      <span class="<%= label_classes %>">
        <%= @label %>
        <% if @required %><span class="text-red-500">*</span><% end %>
      </span>
      <% if @description.present? %>
        <p class="<%= description_classes %>">
          <%= @description %>
        </p>
      <% end %>
      <% if @error.present? %>
        <p class="<%= error_classes %>"><%= @error %></p>
      <% end %>
    </div>
  <% end %>
</label>
