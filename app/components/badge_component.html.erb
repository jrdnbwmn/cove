<span class="<%= wrapper_classes %>">
  <%= @text %>
  <% if @dot %>
    <div class="<%= dot_classes %>"></div>
  <% end %>
  <% if @removable %>
    <button type="button" class="<%= remove_button_classes %>">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="<%= icon_size %>">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
      </svg>
    </button>
  <% end %>
</span>
